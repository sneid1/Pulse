# Build output
/build/
/dist/

# CMake/native build byproducts that can escape the build dir
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
*.ilk
*.idb
*.iobj
*.ipdb
*.tlog
*.lastbuildstate
*.vcxproj.user
*.suo
*.user

# Vendored deps: provisioned by tools/Provision-ThirdParty.ps1 (pinned, re-creatable).
# Keep the manifest tracked; ignore the heavy binaries/headers.
/third_party/*
!/third_party/README.md

# Bundled Blender authoring tool (installed/junctioned locally, never tracked)
/tools/blender/blender-5.1.2-windows-x64/

# Python cache artifacts
__pycache__/
*.py[cod]

# Blender scratch/backups and local workbench exports
*.blend[0-9]*
/tools/blender/*.blend
/tools/blender/*.glb
/tools/blender/*_report.txt

# Compiled shader / build artifacts
*.dxil
*.cso
*.pdb
*.obj
!assets/**/*.obj

# Headless verify-loop captures and generated review media
/captures/
/_uireview/
/_uiwork/
*.bmp
*.mp4

# Local design/marketing/export workspaces
/Design Guide/
/Environment designed/
/Marketing/
/New Models/
/Pulse Menus Design/
/Pulse Beam VFX.dc.html
/enemies_sheet.png

# OS / editor cruft
Thumbs.db
.DS_Store
.vs/
.vscode/
*.tmp
*.bak
*.orig

