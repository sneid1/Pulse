# AAA gunplay profiles. These override the built-in defaults at startup and on F5.
# Keep reward/content metadata in config/pulse.content; this file owns feel, viewmodel,
# recoil, animation windows, VFX, and readiness.
#
# Sections are stable weapon ids: pistol, ak47, carbine, pulse_smg, machine_pistol,
# scattergun, marksman, railbolt.

[pistol]
role = semi-auto sidearm
automatic = 0
damage = 22
fireRate = 7.0
magazine = 12
reserve = 36
reloadSeconds = 1.0
firstShotInaccuracyDeg = 0.035
sprayInaccuracyDeg = 0.06
moveInaccuracyDeg = 0.55
recoilPitchScale = 0.72
recoilYawScale = 0.42
recoilRecoveryRate = 16.0
recoilResetSeconds = 0.22
cameraKickRecovery = 24.0
cameraKick = 2.7
fovPunch = 1.8
viewmodelKick = 0.92
viewmodelKickRecovery = 22.0
viewmodelSideScale = 0.10
fireVolume = 2.15
muzzleFlashSeconds = 0.044
muzzleFlashScale = 0.64
tracerSeconds = 0.038
impactScale = 0.90
muzzleFlashR = 255
muzzleFlashG = 214
muzzleFlashB = 136
tracerR = 255
tracerG = 218
tracerB = 134
tracerWidthScale = 0.56
tracerAlphaScale = 0.76
casingScale = 0.72
