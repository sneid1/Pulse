viewmodel.yaw = -0.108
viewmodel.pitch = -0.092
viewmodel.roll = -0.016
viewmodel.idleDampScale = 0.35
viewmodel.muzzleA = muzzlebreak
viewmodel.muzzleB = base
viewmodel.authored = 1

